# Environment variables with API keys
.env

# Local copies of LLM properties that may carry literal API keys.
# The committed templates use ${ENV_VAR} resolution; if you create a copy
# with the literal key, name it *-local.properties or *-secret.properties
# so it stays out of the repo.
*-local.properties
*-secret.properties

# Project-local API-key files read by LLMConfig.resolveEnvPlaceholder when
# IntelliJ env-var injection or shell exports aren't available. Each file is
# named after the env var it stands in for (e.g. .api_keys/DEEPSEEK_API_KEY)
# and contains just the secret on a single line.
.api_keys/
