# Ignore everything inside .idea/ except the shared MIST run
# configurations — those are checked in so a fresh IntelliJ open
# gets the right Working Directory + program arguments.
/.idea/*
!/.idea/runConfigurations/
# Claude Code's per-agent worktrees / scratch state.
/.claude/
/.settings/
/.vscode/
/.classpath/
/.project/
/bin/
/target
# Stage 1.C: Maven reactor — also ignore target/ inside every module
**/target/
/logs/
# Stage 1.C: Maven reactor — also ignore logs/ inside every module
**/logs/
# MIST runtime state (LLM cache, etc.). Survives `mvn clean`; un-ignore
# for artifact bundles to commit a blessed cache for reproducibility.
/.mist/
# Stage 1.C: Maven reactor — also ignore .mist/ inside every module
**/.mist/
/log/*

/allure-results/
